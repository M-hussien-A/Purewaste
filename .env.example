# ===========================================
# Foundry Management System - Environment Variables
# ===========================================

# --- Database (Neon Serverless Postgres) ---
# Pooled connection (for app runtime via Prisma Client)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct connection (for migrations/introspection via Prisma CLI)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- NextAuth v5 ---
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Note: On Vercel, NEXTAUTH_URL is auto-detected — only set for local dev

# --- App Config ---
DEFAULT_LOCALE="ar"
