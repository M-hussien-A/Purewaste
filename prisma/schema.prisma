generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  ACCOUNTANT
  VIEWER
}

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
}

enum PaymentType {
  PAYABLE
  RECEIVABLE
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  FAILED_LOGIN
  EXPORT
  PASSWORD_CHANGE
}

enum BatchStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  fullName      String
  phone         String?
  passwordHash  String
  role          UserRole  @default(VIEWER)
  languagePref  String    @default("ar")
  themePref     String    @default("light")
  isActive      Boolean   @default(true)
  failedLogins  Int       @default(0)
  lockedUntil   DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs          AuditLog[]
  sessions           Session[]
  createdPurchases   Purchase[]       @relation("PurchaseCreator")
  createdBatches     SmeltingBatch[]  @relation("BatchCreator")
  createdSales       Sale[]           @relation("SaleCreator")
  createdPayments    Payment[]        @relation("PaymentCreator")
  inventoryMovements InventoryMovement[]
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String
  action     AuditAction
  module     String
  recordId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([timestamp])
}

model RawMaterial {
  id            String  @id @default(cuid())
  name          String
  nameAr        String
  category      String
  unit          String  @default("kg")
  minStockLevel Decimal @default(0) @db.Decimal(12, 2)
  currentStock  Decimal @default(0) @db.Decimal(12, 2)
  avgCostPerKg  Decimal @default(0) @db.Decimal(12, 4)
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchases   Purchase[]
  batchInputs BatchInput[]
  movements   InventoryMovement[] @relation("RawMaterialMovements")
}

model FinishedProduct {
  id            String  @id @default(cuid())
  name          String
  nameAr        String
  category      String
  sizeType      String?
  unit          String  @default("kg")
  minStockLevel Decimal @default(0) @db.Decimal(12, 2)
  currentStock  Decimal @default(0) @db.Decimal(12, 2)
  avgCostPerKg  Decimal @default(0) @db.Decimal(12, 4)
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  batchOutputs BatchOutput[]
  sales        Sale[]
  movements    InventoryMovement[] @relation("FinishedProductMovements")
}

model Supplier {
  id           String  @id @default(cuid())
  name         String
  nameAr       String?
  phone        String?
  address      String?
  paymentTerms Int     @default(0)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchases Purchase[]
  payments  Payment[]  @relation("SupplierPayments")
}

model Customer {
  id           String  @id @default(cuid())
  name         String
  nameAr       String?
  phone        String?
  address      String?
  paymentTerms Int     @default(0)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sales    Sale[]
  payments Payment[] @relation("CustomerPayments")
}

model Purchase {
  id            String        @id @default(cuid())
  date          DateTime
  supplierId    String
  materialId    String
  quantity      Decimal       @db.Decimal(12, 2)
  unitPrice     Decimal       @db.Decimal(12, 4)
  totalCost     Decimal       @db.Decimal(14, 2)
  paymentStatus PaymentStatus @default(PENDING)
  paidAmount    Decimal       @default(0) @db.Decimal(14, 2)
  notes         String?
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  supplier  Supplier    @relation(fields: [supplierId], references: [id])
  material  RawMaterial @relation(fields: [materialId], references: [id])
  creator   User        @relation("PurchaseCreator", fields: [createdBy], references: [id])
  payments  Payment[]   @relation("PurchasePayments")

  @@index([supplierId])
  @@index([date])
}

model SmeltingBatch {
  id              String      @id @default(cuid())
  batchNumber     Int         @unique @default(autoincrement())
  date            DateTime
  status          BatchStatus @default(COMPLETED)
  totalInputQty   Decimal     @db.Decimal(12, 2)
  totalOutputQty  Decimal     @db.Decimal(12, 2)
  lossRatio       Decimal     @db.Decimal(6, 4)
  electricityHrs  Decimal     @default(0) @db.Decimal(8, 2)
  laborHrs        Decimal     @default(0) @db.Decimal(8, 2)
  otherExpenses   Decimal     @default(0) @db.Decimal(14, 2)
  materialCost    Decimal     @db.Decimal(14, 2)
  operatingCost   Decimal     @db.Decimal(14, 2)
  maintenanceAlloc Decimal    @default(0) @db.Decimal(14, 2)
  totalCost       Decimal     @db.Decimal(14, 2)
  costPerKg       Decimal     @db.Decimal(12, 4)
  notes           String?
  createdBy       String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  inputs  BatchInput[]
  outputs BatchOutput[]
  sales   Sale[]
  creator User @relation("BatchCreator", fields: [createdBy], references: [id])

  @@index([date])
}

model BatchInput {
  id         String  @id @default(cuid())
  batchId    String
  materialId String
  quantity   Decimal @db.Decimal(12, 2)
  unitCost   Decimal @db.Decimal(12, 4)

  batch    SmeltingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  material RawMaterial   @relation(fields: [materialId], references: [id])
}

model BatchOutput {
  id        String  @id @default(cuid())
  batchId   String
  productId String
  quantity  Decimal @db.Decimal(12, 2)
  costPerKg Decimal @db.Decimal(12, 4)

  batch   SmeltingBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  product FinishedProduct @relation(fields: [productId], references: [id])
}

model Sale {
  id            String        @id @default(cuid())
  date          DateTime
  customerId    String
  productId     String
  batchId       String?
  quantity      Decimal       @db.Decimal(12, 2)
  pricePerKg    Decimal       @db.Decimal(12, 4)
  totalRevenue  Decimal       @db.Decimal(14, 2)
  costPerKg     Decimal       @db.Decimal(12, 4)
  grossProfit   Decimal       @db.Decimal(14, 2)
  paymentStatus PaymentStatus @default(PENDING)
  paidAmount    Decimal       @default(0) @db.Decimal(14, 2)
  notes         String?
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer Customer        @relation(fields: [customerId], references: [id])
  product  FinishedProduct @relation(fields: [productId], references: [id])
  batch    SmeltingBatch?  @relation(fields: [batchId], references: [id])
  creator  User            @relation("SaleCreator", fields: [createdBy], references: [id])
  payments Payment[]       @relation("SalePayments")

  @@index([customerId])
  @@index([date])
}

model Payment {
  id           String        @id @default(cuid())
  date         DateTime
  type         PaymentType
  amount       Decimal       @db.Decimal(14, 2)
  method       PaymentMethod
  supplierId   String?
  customerId   String?
  purchaseId   String?
  saleId       String?
  notes        String?
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  supplier  Supplier? @relation("SupplierPayments", fields: [supplierId], references: [id])
  customer  Customer? @relation("CustomerPayments", fields: [customerId], references: [id])
  purchase  Purchase? @relation("PurchasePayments", fields: [purchaseId], references: [id])
  sale      Sale?     @relation("SalePayments", fields: [saleId], references: [id])
  creator   User      @relation("PaymentCreator", fields: [createdBy], references: [id])

  @@index([type])
  @@index([date])
}

model InventoryMovement {
  id                String       @id @default(cuid())
  date              DateTime     @default(now())
  type              MovementType
  rawMaterialId     String?
  finishedProductId String?
  quantity          Decimal      @db.Decimal(12, 2)
  reason            String
  referenceId       String?
  userId            String
  createdAt         DateTime     @default(now())

  rawMaterial     RawMaterial?     @relation("RawMaterialMovements", fields: [rawMaterialId], references: [id])
  finishedProduct FinishedProduct? @relation("FinishedProductMovements", fields: [finishedProductId], references: [id])
  user            User             @relation(fields: [userId], references: [id])

  @@index([rawMaterialId])
  @@index([finishedProductId])
  @@index([date])
}

model SystemSettings {
  id                String  @id @default("system")
  electricityRate   Decimal @default(5) @db.Decimal(10, 2)
  laborRate         Decimal @default(20) @db.Decimal(10, 2)
  monthlyMaintenance Decimal @default(1500) @db.Decimal(14, 2)
  defaultLanguage   String  @default("ar")
  defaultTheme      String  @default("light")
  foundryName       String  @default("المسبك")
  foundryNameEn     String  @default("The Foundry")
  updatedAt         DateTime @updatedAt
}
